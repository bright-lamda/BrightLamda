NODE_ENV=development
PORT=4000
APP_ORIGIN=http://localhost:8081

# Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co

# Server-only key. Prefer a Supabase secret key if available, or legacy service_role key.
# Never expose this in Expo/mobile code and never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-secret-or-service-role-key
SUPABASE_STORAGE_BUCKET=bright-lamda-content

# Use Supabase Session Pooler for persistent Node servers on IPv4-only networks.
# Use Transaction Pooler for serverless deployments and disable prepared statements.
DATABASE_URL=postgres://postgres.project_ref:password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

# Bright AI providers. Start with mock locally, then use Groq or Gemini when ready.
AI_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=supabase
AI_INGESTION_BATCH_SIZE=5
