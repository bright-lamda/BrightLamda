# Bright Lamda Mobile Environment

# Local backend during development
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# Supabase client-side values. These are public/mobile-safe values only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# If your Supabase project still uses legacy JWT keys, use the anon key as the public key.
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-legacy-anon-key
